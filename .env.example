# Required. The Claude API key that powers the entire grading chain.
# Keep the real key only in .env.local.
ANTHROPIC_API_KEY=

# Optional Claude model overrides.
ANTHROPIC_WORK_MODEL=claude-opus-4-8
ANTHROPIC_JUDGE_MODEL=claude-opus-4-8

# Optional. Enables semantic course retrieval (embeddings only). Without it,
# retrieval falls back to lexical ranking and no data is sent to OpenAI.
OPENAI_API_KEY=

# Optional embedding overrides used by `npm run index:semantic`.
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_EMBEDDING_DIMENSIONS=1024

# Optional stable salt for pseudonymous per-student request identifiers.
SAFETY_IDENTIFIER_SALT=replace-with-a-random-secret

# Optional absolute path for the JSON run store.
# FEEDBACK_DATA_DIR=/absolute/path/to/private/data

# Optional absolute path for the private semantic index.
# SEMANTIC_INDEX_PATH=/absolute/path/to/semantic-index-v1.json
